---
import Layout from "@/layouts/Layout.astro";
import Hero from "@/components/Hero.astro";
import heroDesktop from "@/assets/images/hero.webp";
import heroMobile from "@/assets/images/hero-mobile.webp";
import Schedule from "@/components/Schedule.astro";
import Services from "@/components/Services.astro";
import AboutMe from "@/components/AboutMe.astro";
import Positions from "@/components/Positions.astro";
import CTAWhatsApp from "@/components/CTAWhatsApp.astro";
import YogaFacial from "@/components/YogaFacial.astro";
import Kobido from "@/components/Kobido.astro";
import GallerySection from "@/components/GallerySection.astro";
import Events from "@/components/Events.astro";
import FAQ from "@/components/FAQ.astro";
import Footer from "@/components/Footer.astro";
---

<Layout>
  <Fragment slot="head">
    <link
      rel="preload"
      as="image"
      href={heroMobile.src}
      media="(max-width: 767px)"
      fetchpriority="high"
    />
    <link
      rel="preload"
      as="image"
      href={heroDesktop.src}
      media="(min-width: 768px)"
      fetchpriority="high"
    />
  </Fragment>
  <Hero />
  <AboutMe />
  <Positions />
  <Schedule />
  <Services />
  <CTAWhatsApp />
  <YogaFacial />
  <Kobido />
  <Events />
  <GallerySection />
  <FAQ />
  <Footer />
</Layout>
