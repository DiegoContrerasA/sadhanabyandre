---
const links = [
  { label: "Sobre mí",             href: "#sobre-mi" },
  { label: "Servicios",            href: "#servicios" },
  { label: "Kobido",               href: "#kobido" },
  { label: "Horarios",             href: "#horarios" },
  { label: "Faq", href: "#faq" },
];
---

<header class="relative h-dvh w-full bg-[url(../assets/images/hero.jpeg)] bg-cover bg-center overflow-hidden">
  <!-- Navbar -->
  <nav
    id="navbar"
    class="fixed inset-x-0 top-0 z-50 flex justify-center items-center transition-all duration-500 px-8 h-20 backdrop-blur-[8px]"
    aria-label="Navegación principal"
  >

      <!-- Desktop links -->
      <ul class="hidden md:flex items-center gap-10 list-none" role="list">
        {links.map(l => (
          <li>
            <a
              href={l.href}
              class="nav-link inline-block text-white/80 text-sm tracking-[0.22em] uppercase no-underline transition-colors duration-300 hover:text-white  [text-shadow:0_1px_12px_rgba(0,0,0,0.55)] hover:underline hover:underline-offset-6"
            >
              {l.label}
            </a>
          </li>
        ))}
      </ul>

  </nav>

  <!-- Hamburger / X toggle (mobile only) — z-index above mobile menu -->
  <button
    id="nav-toggle"
    class="md:hidden fixed top-0 right-8 z-[200] h-20 flex flex-col items-center justify-center gap-[5px] bg-transparent border-0 cursor-pointer text-white"
    aria-label="Abrir menú"
    aria-controls="mobile-menu"
    aria-expanded="false"
  >
    <span class="burger-line block w-[22px] h-px bg-current transition duration-[400ms] ease-in-out"></span>
    <span class="burger-line block w-[22px] h-px bg-current transition duration-[400ms] ease-in-out"></span>
    <span class="burger-line block w-[22px] h-px bg-current transition duration-[400ms] ease-in-out"></span>
  </button>

  <!-- Mobile full-screen overlay -->
  <div
    id="mobile-menu"
    class="fixed inset-0 z-[150] flex flex-col items-center justify-center pb-12 bg-primary"
    aria-hidden="true"
    role="dialog"
    aria-modal="true"
    aria-label="Menú de navegación"
  >
    <ul class="flex-1 flex flex-col items-center justify-center gap-10 list-none w-full" role="list">
      {links.map(l => (
        <li>
          <a
            href={l.href}
            class="mobile-link text-2xl inline-block font-light text-white/70 uppercase no-underline text-center transition-colors duration-250 hover:text-white"
          >
            {l.label}
          </a>
        </li>
      ))}
    </ul>
  </div>

  <!-- Scroll indicator -->
  <!-- <div class="absolute bottom-8 inset-x-0 flex flex-col items-center gap-2 pointer-events-none z-10 text-primary" aria-hidden="true">
    <div class="scroll-arrow flex flex-col items-center gap-[3px]">
      <svg width="16" height="10" viewBox="0 0 16 10" fill="none" xmlns="http://www.w3.org/2000/svg">
        <path d="M1 1L8 8L15 1" stroke="currentColor" stroke-opacity="1" stroke-width="4" stroke-linecap="round" stroke-linejoin="round"/>
      </svg>
      <svg width="16" height="10" viewBox="0 0 16 10" fill="none" xmlns="http://www.w3.org/2000/svg">
        <path d="M1 1L8 8L15 1" stroke="currentColor" stroke-opacity="0.9" stroke-width="4" stroke-linecap="round" stroke-linejoin="round"/>
      </svg>
    </div>
  </div> -->

</header>

<style>

  /* Scroll indicator */
  .scroll-arrow {
    animation: scroll-bounce 1.8s ease-in-out infinite;
  }
  @keyframes scroll-bounce {
    0%, 100% { transform: translateY(0);     opacity: 1; }
    50%       { transform: translateY(6px);  opacity: 0.5; }
  }

  /* Mobile overlay: closed by default, opens with .is-open */
  #mobile-menu {
    transform: translateX(100%);
    transition: transform 0.45s cubic-bezier(0.77, 0, 0.175, 1);
    pointer-events: none;
  }
  #mobile-menu.is-open {
    transform: translateX(0);
    pointer-events: auto;
  }

  /* Hamburger → X */
  #nav-toggle.is-open .burger-line:nth-child(1) {
    transform: translateY(6px) rotate(45deg);
  }
  #nav-toggle.is-open .burger-line:nth-child(2) {
    opacity: 0;
    transform: scaleX(0);
  }
  #nav-toggle.is-open .burger-line:nth-child(3) {
    transform: translateY(-6px) rotate(-45deg);
  }
</style>

<script>
  const $toggle = document.getElementById("nav-toggle")!;
  const $menu   = document.getElementById("mobile-menu")!;

  const openMenu = () => {
    $menu.classList.add("is-open");
    $toggle.classList.add("is-open");
    $menu.setAttribute("aria-hidden", "false");
    $toggle.setAttribute("aria-expanded", "true");
    $toggle.setAttribute("aria-label", "Cerrar menú");
    document.body.style.overflow = "hidden";
  };

  const closeMenu = () => {
    $menu.classList.remove("is-open");
    $toggle.classList.remove("is-open");
    $menu.setAttribute("aria-hidden", "true");
    $toggle.setAttribute("aria-expanded", "false");
    $toggle.setAttribute("aria-label", "Abrir menú");
    document.body.style.overflow = "";
  };

  $toggle.addEventListener("click", () => {
    $menu.classList.contains("is-open") ? closeMenu() : openMenu();
  });

  $menu.querySelectorAll(".mobile-link").forEach(l => l.addEventListener("click", closeMenu));
</script>
