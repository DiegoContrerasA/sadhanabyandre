---
import logo from "@/assets/images/logo.png";
import { useTranslations, getLang } from "@/i18n";
import { getRelativeLocaleUrl } from "astro:i18n";

const lang = getLang(Astro.currentLocale);
const t = useTranslations(lang);
const esUrl = getRelativeLocaleUrl("es", "");
const enUrl = getRelativeLocaleUrl("en", "");
const nav = t("nav");
const hero = t("hero");

const wa = (msg: string) => `https://wa.me/573122861377?text=${encodeURIComponent(msg)}`;
---

<header id="hero-header" class="relative h-dvh w-full bg-cover bg-center overflow-hidden">
  <!-- Navbar -->
  <nav
    id="navbar"
    class="fixed inset-x-0 top-0 z-50 flex justify-center items-center transition-all duration-500 px-8 h-20 backdrop-blur-[8px]"
    aria-label={nav.ariaNav}
  >

      <!-- Desktop links -->
      <ul class="hidden md:flex items-center gap-10 list-none" role="list">
        {nav.links.map(l => (
          <li>
            <a
              href={l.href}
              class="nav-link inline-block text-white/80 text-sm tracking-[0.22em] uppercase no-underline transition-colors duration-300 hover:text-white  [text-shadow:0_1px_12px_rgba(0,0,0,0.55)] hover:underline hover:underline-offset-6"
            >
              {l.label}
            </a>
          </li>
        ))}
      </ul>

      <!-- Desktop lang toggle -->
      <div class="absolute right-8 hidden md:flex items-center gap-2 text-[11px] tracking-[0.22em] uppercase">
        <a href={esUrl} class={`transition-colors duration-300 [text-shadow:0_1px_8px_rgba(0,0,0,0.5)] ${lang === 'es' ? 'text-white' : 'text-white/40 hover:text-white/70'}`}>ES</a>
        <span class="text-white/25">|</span>
        <a href={enUrl} class={`transition-colors duration-300 [text-shadow:0_1px_8px_rgba(0,0,0,0.5)] ${lang === 'en' ? 'text-white' : 'text-white/40 hover:text-white/70'}`}>EN</a>
      </div>

  </nav>

  <!-- Mobile lang toggle -->
  <div class="md:hidden fixed top-0 left-8 z-[200] h-20 flex items-center gap-2 text-[11px] tracking-[0.22em] uppercase">
    <a href={esUrl} class={`transition-colors duration-300 [text-shadow:0_1px_8px_rgba(0,0,0,0.5)] ${lang === 'es' ? 'text-white' : 'text-white/40'}`}>ES</a>
    <span class="text-white/25">|</span>
    <a href={enUrl} class={`transition-colors duration-300 [text-shadow:0_1px_8px_rgba(0,0,0,0.5)] ${lang === 'en' ? 'text-white' : 'text-white/40'}`}>EN</a>
  </div>

  <!-- Hamburger / X toggle (mobile only) — z-index above mobile menu -->
  <button
    id="nav-toggle"
    class="md:hidden fixed top-0 right-8 z-[200] h-20 flex flex-col items-center justify-center gap-[5px] bg-transparent border-0 cursor-pointer text-white"
    aria-label={nav.openMenu}
    aria-controls="mobile-menu"
    aria-expanded="false"
    data-open-label={nav.openMenu}
    data-close-label={nav.closeMenu}
  >
    <span class="burger-line block w-[22px] h-px bg-current transition duration-[400ms] ease-in-out"></span>
    <span class="burger-line block w-[22px] h-px bg-current transition duration-[400ms] ease-in-out"></span>
    <span class="burger-line block w-[22px] h-px bg-current transition duration-[400ms] ease-in-out"></span>
  </button>

  <!-- Mobile full-screen overlay -->
  <div
    id="mobile-menu"
    class="fixed inset-0 z-[150] flex flex-col items-center justify-center pb-12 bg-primary"
    aria-hidden="true"
    role="dialog"
    aria-modal="true"
    aria-label={nav.ariaNavMobile}
  >
    <ul class="flex-1 flex flex-col items-center justify-center gap-10 list-none w-full" role="list">
      {nav.links.map(l => (
        <li>
          <a
            href={l.href}
            class="mobile-link text-2xl inline-block font-light text-white/70 uppercase no-underline text-center transition-colors duration-250 hover:text-white"
          >
            {l.label}
          </a>
        </li>
      ))}
    </ul>
  </div>

  <!-- Dark overlay -->
  <div class="absolute inset-0 bg-black/40 z-0"></div>

  <!-- Hero content — logo + tagline -->
  <div class="relative z-1 flex flex-col items-center md:items-start justify-between sm:justify-start md:justify-center py-28 md:py-0 px-12 max-w-7xl mx-auto h-full">
    <div class="flex flex-col gap-5 md:gap-10">
      <div class="flex flex-col items-center md:items-start">
        <img
          src={logo.src}
          alt={hero.logoAlt}
          fetchpriority="high"
          loading="eager"
          decoding="async"
          class="hero-item w-72 md:w-96 object-contain drop-shadow-[0_2px_18px_rgba(0,0,0,0.45)]"
          style="animation-delay: 0.1s"
        />
        <p class="hero-item text-white/60 text-xs tracking-[0.35em] uppercase" style="animation-delay: 0.25s">
          {hero.byline}
        </p>
      </div>

      <!-- Tagline — 2 líneas -->
      <div class="space-y-1 text-white md:text-white/80 text-center md:text-left">
        <p class="hero-item text-lg md:text-xl font-light tracking-[0.18em] uppercase [text-shadow:0_1px_12px_rgba(0,0,0,0.5)]" style="animation-delay: 0.4s">
          {hero.tagline1}
        </p>
        <p class="hero-item text-base md:text-lg font-light tracking-[0.18em] uppercase [text-shadow:0_1px_12px_rgba(0,0,0,0.5)]" style="animation-delay: 0.52s">
          {hero.tagline2}
        </p>
      </div>
    </div>

    <!-- CTA -->
    <a
      href={wa(hero.waMessage)}
      target="_blank"
      rel="noopener noreferrer"
      class="hero-item my-10 inline-flex items-center justify-center px-8 h-[52px] text-xs tracking-[0.28em] uppercase bg-primary text-white transition-opacity duration-300 hover:opacity-80"
      style="animation-delay: 0.65s"
    >
      {hero.cta}
    </a>
  </div>

  <!-- Stats bar — bottom -->
  <div class="hero-item absolute bottom-0 inset-x-0 z-10" style="animation-delay: 0.75s">
    <div class="flex divide-x divide-white/20 bg-black/30 backdrop-blur-sm">
      {hero.stats.map(s => (
        <div class="flex-1 flex flex-col items-center justify-center py-5 px-4 gap-0.5">
          <span class="text-white text-2xl md:text-3xl font-semibold tracking-tight [text-shadow:0_1px_8px_rgba(0,0,0,0.4)]">
            {s.value}
          </span>
          <span class="text-white/70 text-[11px] md:text-xs tracking-[0.18em] uppercase text-center">
            {s.label}
          </span>
        </div>
      ))}
    </div>
  </div>

</header>

<style>

  /* Hero entrance animation */
  @keyframes hero-in {
    from { opacity: 0; transform: translateY(22px); }
    to   { opacity: 1; transform: translateY(0); }
  }
  .hero-item {
    opacity: 1;
  }
  @media (min-width: 768px) {
    .hero-item {
      opacity: 0;
      animation: hero-in 0.7s cubic-bezier(0.22, 1, 0.36, 1) forwards;
    }
  }
  @media (min-width: 768px) and (prefers-reduced-motion: reduce) {
    .hero-item { opacity: 1; animation: none; }
  }

  /* Background images — mobile uses portrait crop, desktop uses landscape */
  #hero-header {
    background-image: url('../assets/images/hero-mobile.webp');
    background-position: center top;
  }
  @media (min-width: 768px) {
    #hero-header {
      background-image: url('../assets/images/hero.webp');
      background-position: center center;
    }
  }

  /* Scroll indicator */
  .scroll-arrow {
    animation: scroll-bounce 1.8s ease-in-out infinite;
  }
  @keyframes scroll-bounce {
    0%, 100% { transform: translateY(0);     opacity: 1; }
    50%       { transform: translateY(6px);  opacity: 0.5; }
  }

  /* Mobile overlay: closed by default, opens with .is-open */
  #mobile-menu {
    transform: translateX(100%);
    transition: transform 0.25s cubic-bezier(0.77, 0, 0.175, 1);
    pointer-events: none;
  }
  #mobile-menu.is-open {
    transform: translateX(0);
    pointer-events: auto;
  }

  /* Hamburger → X */
  #nav-toggle.is-open .burger-line:nth-child(1) {
    transform: translateY(6px) rotate(45deg);
  }
  #nav-toggle.is-open .burger-line:nth-child(2) {
    opacity: 0;
    transform: scaleX(0);
  }
  #nav-toggle.is-open .burger-line:nth-child(3) {
    transform: translateY(-6px) rotate(-45deg);
  }
</style>

<script>
  const $toggle = document.getElementById("nav-toggle")!;
  const $menu   = document.getElementById("mobile-menu")!;
  const openLabel  = $toggle.dataset.openLabel  ?? "Open menu";
  const closeLabel = $toggle.dataset.closeLabel ?? "Close menu";

  const openMenu = () => {
    $menu.classList.add("is-open");
    $toggle.classList.add("is-open");
    $menu.setAttribute("aria-hidden", "false");
    $toggle.setAttribute("aria-expanded", "true");
    $toggle.setAttribute("aria-label", closeLabel);
    document.body.style.overflow = "hidden";
  };

  const closeMenu = () => {
    $menu.classList.remove("is-open");
    $toggle.classList.remove("is-open");
    $menu.setAttribute("aria-hidden", "true");
    $toggle.setAttribute("aria-expanded", "false");
    $toggle.setAttribute("aria-label", openLabel);
    document.body.style.overflow = "";
  };

  $toggle.addEventListener("click", () => {
    $menu.classList.contains("is-open") ? closeMenu() : openMenu();
  });

  $menu.querySelectorAll(".mobile-link").forEach(l => l.addEventListener("click", closeMenu));
</script>
