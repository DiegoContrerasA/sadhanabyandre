---
import { useTranslations, getLang } from "@/i18n";

const schedule = useTranslations(getLang(Astro.currentLocale))("schedule");

const wa = (msg: string) => `https://wa.me/573122861377?text=${encodeURIComponent(msg)}`;
---

<section id="horarios" class="bg-white px-6 md:px-12 py-24 md:py-32">
  <div class="max-w-7xl mx-auto">

    <!-- Top divider -->
    <div class="w-px h-16 bg-primary/25 mx-auto mb-16"></div>

    <!-- Header -->
    <div class="text-center mb-20">
      <p data-animate class=" text-[0.65rem] tracking-[0.35em] uppercase text-primary mb-4">
        {schedule.label}
      </p>
      <h2 data-animate data-delay="100" class=" text-4xl md:text-5xl lg:text-6xl font-light text-zinc-800">
        {schedule.heading} <em class="italic text-primary">{schedule.headingEm}</em>
      </h2>
    </div>

    <!-- Class list -->
    <div class="flex flex-col">
      {schedule.items.map((item, i) => {
        const tags = item.online
          ? [schedule.tagPresencial, schedule.tagOnline]
          : [schedule.tagPresencial];
        return (
          <div data-animate data-delay={i * 80} class="group flex flex-col lg:flex-row lg:items-center gap-6 py-10 border-t border-primary/15">

            <!-- Day + Time -->
            <div class="sm:w-24 shrink-0">
              <p class=" text-2xl md:text-3xl font-light text-primary ">
                {item.day}
              </p>
              <p class=" text-sm tracking-wide mt-0.5">
                {item.time}
              </p>
            </div>

            <!-- Divider vertical (desktop) -->
            <div class="hidden lg:block w-px h-10 bg-primary/15 flex-shrink-0 mx-4" aria-hidden="true"></div>

            <!-- Description -->
            <div class="flex-1">
              <span class="text-zinc-800 text-[0.6rem] font-medium tracking-widest uppercase block">
                {schedule.classLabel}
              </span>
              <p class="text-2xl md:text-3xl leading-relaxed text-primary font-light mb-3">
                {item.name}
              </p>
              <p class="text-sm leading-relaxed text-zinc-500 max-w-xl">
                {item.description}
              </p>
            </div>

            <!-- Badge + CTA -->
            <div class="flex gap-2">
              {tags.map((tag: string) => (
                <span class="inline-flex w-fit items-center px-5 py-3 rounded-full bg-neutral/40 text-primary text-xs whitespace-nowrap">
                  {tag}
                </span>
              ))}
              <a
                href={wa(schedule.waMessage(item.name, item.day, item.time))}
                target="_blank"
                rel="noopener noreferrer"
                class=" inline-flex w-fit  items-center gap-2 px-5 py-3 rounded-full border border-primary/25 text-primary text-xs tracking-widest uppercase transition-all duration-300 hover:bg-primary hover:text-primary-light hover:border-primary whitespace-nowrap"
              >
                {schedule.reserveBtn}
                <svg width="12" height="12" viewBox="0 0 18 18" fill="none" aria-hidden="true" class="transition-transform duration-200 group-hover:translate-x-0.5">
                  <path d="M3.75 14.25L14.25 3.75M14.25 3.75H6.75M14.25 3.75V11.25" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
              </a>
            </div>
          </div>
        );
      })}
      <div class="border-t border-primary/15"></div>
    </div>

    <!-- Footer note -->
    <p class="mt-10  text-[0.65rem] tracking-[0.2em] uppercase">
      {schedule.note}
    </p>

  </div>
</section>
