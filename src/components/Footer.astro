---
const year = new Date().getFullYear();

const links = [
  { label: "Sobre mí",             href: "#sobre-mi" },
  { label: "Servicios",            href: "#servicios" },
  { label: "Kobido",               href: "#kobido" },
  { label: "Horarios",             href: "#horarios" },
  { label: "Preguntas frecuentes", href: "#faq" },
];
---

<footer class="bg-black px-6 md:px-12 py-20">
  <div class="max-w-7xl mx-auto">

    <!-- Top divider -->
    <div class="w-px h-16 bg-white/10 mx-auto mb-16"></div>

    <!-- Main grid -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-12 md:gap-16">

      <!-- Brand -->
      <div class="md:col-span-1">
        <p class="[font-family:var(--font-heading)] text-2xl font-light tracking-widest text-white/90 mb-4">
          Sadhana
        </p>
        <p class="[font-family:var(--font-body)] text-sm leading-relaxed text-white/40 max-w-xs">
          Un espacio para reconectarte con tu cuerpo, tu respiración y tu esencia. Yoga con intención, guía y amor.
        </p>
      </div>

      <!-- Nav links -->
      <div>
        <p class="[font-family:var(--font-body)] text-[0.65rem] tracking-[0.35em] uppercase text-white/30 mb-6">
          Secciones
        </p>
        <ul class="flex flex-col gap-3 list-none">
          {links.map(l => (
            <li>
              <a
                href={l.href}
                class="[font-family:var(--font-body)] text-sm text-white/50 hover:text-white transition-colors duration-300 tracking-wide"
              >
                {l.label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Contact -->
      <div>
        <p class="[font-family:var(--font-body)] text-[0.65rem] tracking-[0.35em] uppercase text-white/30 mb-6">
          Contacto
        </p>
        <div class="flex flex-col gap-3">
          <a
            href="https://wa.me/1234567890"
            target="_blank"
            rel="noopener noreferrer"
            class="[font-family:var(--font-body)] inline-flex items-center gap-2.5 text-sm text-white/50 hover:text-white transition-colors duration-300"
          >
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M21 11.5a8.38 8.38 0 0 1-.9 3.8 8.5 8.5 0 0 1-7.6 4.7 8.38 8.38 0 0 1-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 0 1-.9-3.8 8.5 8.5 0 0 1 4.7-7.6 8.38 8.38 0 0 1 3.8-.9h.5a8.48 8.48 0 0 1 8 8v.5z"/>
            </svg>
            WhatsApp
          </a>
          <a
            href="https://instagram.com/sadhanabyandre"
            target="_blank"
            rel="noopener noreferrer"
            class="[font-family:var(--font-body)] inline-flex items-center gap-2.5 text-sm text-white/50 hover:text-white transition-colors duration-300"
          >
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <rect x="2" y="2" width="20" height="20" rx="5" ry="5"/>
              <circle cx="12" cy="12" r="4"/>
              <circle cx="17.5" cy="6.5" r="1" fill="currentColor" stroke="none"/>
            </svg>
            Instagram
          </a>
          <a
            href="https://facebook.com/sadhanabyandre"
            target="_blank"
            rel="noopener noreferrer"
            class="[font-family:var(--font-body)] inline-flex items-center gap-2.5 text-sm text-white/50 hover:text-white transition-colors duration-300"
          >
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"/>
            </svg>
            Facebook
          </a>
        </div>
      </div>

    </div>

    <!-- Bottom bar -->
    <div class="mt-16 pt-8 border-t border-white/8 flex flex-col sm:flex-row sm:items-center sm:justify-between gap-3">
      <p class="[font-family:var(--font-body)] text-[0.65rem] tracking-wide text-white/25">
        © {year} Sadhana by Andre · Todos los derechos reservados
      </p>
      <p class="[font-family:var(--font-body)] text-[0.65rem] tracking-[0.2em] uppercase text-white/15">
        Hecho con intención
      </p>
    </div>

  </div>
</footer>
