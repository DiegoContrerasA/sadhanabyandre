---
const year = new Date().getFullYear();
---

<footer class="bg-[#0a050d] px-8 py-14 md:px-16 lg:px-20">

  <div class="flex flex-col md:flex-row md:items-start md:justify-between gap-12">

    <!-- Brand -->
    <div class="max-w-xs">
      <p class="text-primary-light font-light tracking-tight mb-2" style="font-size: 1.4rem;">
        Sadhana <span class="text-secondary">by Andre</span>
      </p>
      <p class="text-primary-light/40 font-light leading-relaxed text-xs tracking-wide">
        Un espacio para reconectarte con tu cuerpo, tu respiración y tu esencia.
        Yoga con intención, guía y amor.
      </p>
    </div>

    <!-- Nav links -->
    <div class="flex flex-col gap-3">
      <p class="text-[0.6rem] tracking-[0.18em] uppercase text-primary-light/30 font-light mb-1">
        Secciones
      </p>
      {[
        ["Clases Grupales", "#clases"],
        ["Servicios",       "#servicios"],
        ["Sobre Mí",        "#sobre-mi"],
        ["Testimonios",     "#testimonios"],
      ].map(([label, href]) => (
        <a
          href={href}
          class="text-primary-light/55 font-light text-sm tracking-wide hover:text-primary-light transition-colors duration-200"
        >
          {label}
        </a>
      ))}
    </div>

    <!-- Contact + socials -->
    <div class="flex flex-col gap-3">
      <p class="text-[0.6rem] tracking-[0.18em] uppercase text-primary-light/30 font-light mb-1">
        Contacto
      </p>

      <!-- WhatsApp -->
      <a
        href="https://wa.me/1234567890"
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center gap-2 text-primary-light/55 font-light text-sm tracking-wide hover:text-primary-light transition-colors duration-200"
      >
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M21 11.5a8.38 8.38 0 0 1-.9 3.8 8.5 8.5 0 0 1-7.6 4.7 8.38 8.38 0 0 1-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 0 1-.9-3.8 8.5 8.5 0 0 1 4.7-7.6 8.38 8.38 0 0 1 3.8-.9h.5a8.48 8.48 0 0 1 8 8v.5z"/>
        </svg>
        WhatsApp
      </a>

      <!-- Instagram -->
      <a
        href="https://instagram.com/"
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center gap-2 text-primary-light/55 font-light text-sm tracking-wide hover:text-primary-light transition-colors duration-200"
      >
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <rect x="2" y="2" width="20" height="20" rx="5" ry="5"/>
          <circle cx="12" cy="12" r="4"/>
          <circle cx="17.5" cy="6.5" r="1" fill="currentColor" stroke="none"/>
        </svg>
        Instagram
      </a>

      <!-- Facebook -->
      <a
        href="https://facebook.com/"
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center gap-2 text-primary-light/55 font-light text-sm tracking-wide hover:text-primary-light transition-colors duration-200"
      >
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"/>
        </svg>
        Facebook
      </a>
    </div>

  </div>

  <!-- Bottom bar -->
  <div class="mt-14 pt-6 border-t border-primary-light/8 flex flex-col sm:flex-row sm:items-center sm:justify-between gap-3">
    <p class="text-primary-light/25 text-[0.65rem] tracking-wide font-light">
      © {year} Sadhana by Andre · Todos los derechos reservados
    </p>
    <p class="text-primary-light/15 text-[0.6rem] tracking-wide font-light">
      Hecho con intención
    </p>
  </div>

</footer>
