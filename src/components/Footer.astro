---
import { Image } from "astro:assets";
import photo from "../assets/images/me.jpeg";

const year = new Date().getFullYear();

const socials = [
  { label: "Instagram", href: "https://instagram.com/sadhanabyandre" },
  { label: "Facebook",  href: "https://facebook.com/sadhanabyandre" },
  { label: "TikTok",    href: "https://tiktok.com/@sadhanabyandre" },
  { label: "YouTube",   href: "https://youtube.com/@sadhanabyandre" },
];
---

<footer class="bg-black overflow-hidden">

  <!-- Main section -->
  <div class="max-w-7xl mx-auto px-6 md:px-12 pt-24 md:pt-32">
    <div class="grid grid-cols-1 md:grid-cols-2 gap-16 items-end">

      <!-- Left: title + links -->
      <div class="pb-16 md:pb-24">
        <p class="text-[0.65rem] tracking-[0.35em] uppercase text-white/30 mb-8">
          Conecta conmigo
        </p>
        <h2 class="text-5xl md:text-6xl lg:text-[5.5rem] font-light leading-tight text-white mb-14">
          Sigamos<br />en contacto
        </h2>
        <ul class="flex flex-col list-none">
          {socials.map((s, i) => (
            <li class={i < socials.length - 1 ? "border-b border-white/8" : ""}>
              <a
                href={s.href}
                target="_blank"
                rel="noopener noreferrer"
                class="group flex items-center justify-between py-5 text-white/40 hover:text-white transition-colors duration-300"
              >
                <span class="text-2xl md:text-3xl font-light tracking-wide">
                  {s.label}
                </span>
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  width="18"
                  height="18"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="1.5"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  class="opacity-0 group-hover:opacity-100 -translate-x-2 group-hover:translate-x-0 transition-all duration-300"
                  aria-hidden="true"
                >
                  <path d="M7 17L17 7"/><path d="M7 7h10v10"/>
                </svg>
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Right: photo -->
      <div class="hidden md:block self-end">
        <Image
          src={photo}
          alt="Andre — Sadhana by Andre"
          width={560}
          height={680}
          class="w-full object-cover object-top grayscale"
        />
      </div>

    </div>
  </div>

  <!-- Bottom bar -->
  <div class="border-t border-white/8 px-6 md:px-12 py-6">
    <div class="max-w-7xl mx-auto flex flex-col sm:flex-row sm:items-center sm:justify-between gap-2">
      <p class="text-[0.6rem] tracking-wide text-white/20">
        © {year} Sadhana by Andre · Todos los derechos reservados
      </p>
      <p class="text-[0.6rem] tracking-[0.2em] uppercase text-white/10">
        Hecho con intención
      </p>
    </div>
  </div>

</footer>
