---
import { useTranslations, getLang } from "@/i18n";

const faq = useTranslations(getLang(Astro.currentLocale))("faq");

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": faq.items.map(f => ({
    "@type": "Question",
    "name": f.question,
    "acceptedAnswer": { "@type": "Answer", "text": f.answer }
  }))
};
---

<script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />

<section id="faq" class="px-6 md:px-12 py-24 md:py-32">
  <div class="max-w-7xl mx-auto">

    <!-- Top divider -->
    <div class="w-px h-16 bg-primary/25 mx-auto mb-16"></div>

    <!-- Header -->
    <div class="text-center mb-16">
      <p data-animate class=" text-[0.65rem] tracking-[0.35em] uppercase text-primary mb-4">
        {faq.label}
      </p>
      <h2 data-animate data-delay="100" class="text-4xl md:text-5xl lg:text-6xl font-light text-zinc-800">
        {faq.heading} <em class="italic text-primary">{faq.headingEm}</em>
      </h2>
    </div>

    <!-- Accordion -->
    <div>
      {faq.items.map((item, i) => (
        <div data-animate data-delay={i * 60} class="faq-item border-b border-primary/15">
          <button
            class="faq-trigger w-full flex items-center justify-between py-6 text-left gap-4 group"
            aria-expanded="false"
          >
            <span class=" text-xl md:text-2xl font-light text-zinc-800 group-hover:text-primary group-hover:translate-x-2.5 transition-all duration-300">
              {item.question}
            </span>
            <span class="faq-icon shrink-0 w-8 h-8 rounded-full border border-primary flex items-center justify-center text-primary transition-all duration-300">
              <!-- Plus -->
              <svg class="faq-plus" xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
                <path d="M5 12h14"/><path d="M12 5v14"/>
              </svg>
              <!-- Minus -->
              <svg class="faq-minus hidden" xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
                <path d="M5 12h14"/>
              </svg>
            </span>
          </button>

          <div class="faq-body overflow-hidden" style="max-height: 0; transition: max-height 0.4s cubic-bezier(0.22,1,0.36,1);">
            <p class=" text-base leading-relaxed text-zinc-500 pb-6 max-w-2xl">
              {item.answer}
            </p>
          </div>
        </div>
      ))}
    </div>

  </div>
</section>

<script>
  document.querySelectorAll(".faq-item").forEach((item) => {
    const trigger = item.querySelector(".faq-trigger")!;
    const body    = item.querySelector(".faq-body") as HTMLElement;
    const icon    = item.querySelector(".faq-icon")!;
    const plus    = item.querySelector(".faq-plus")!;
    const minus   = item.querySelector(".faq-minus")!;

    trigger.addEventListener("click", () => {
      const isOpen = trigger.getAttribute("aria-expanded") === "true";

      // Close all
      document.querySelectorAll(".faq-item").forEach((other) => {
        const otherTrigger = other.querySelector(".faq-trigger")!;
        const otherBody    = other.querySelector(".faq-body") as HTMLElement;
        const otherIcon    = other.querySelector(".faq-icon")!;
        const otherPlus    = other.querySelector(".faq-plus")!;
        const otherMinus   = other.querySelector(".faq-minus")!;
        otherTrigger.setAttribute("aria-expanded", "false");
        otherBody.style.maxHeight = "0";
        otherIcon.classList.remove("!bg-primary", "!text-primary-light");
        otherPlus.classList.remove("hidden");
        otherMinus.classList.add("hidden");
      });

      // Open if was closed
      if (!isOpen) {
        trigger.setAttribute("aria-expanded", "true");
        body.style.maxHeight = body.scrollHeight + "px";
        icon.classList.add("!bg-primary", "!text-primary-light");
        plus.classList.add("hidden");
        minus.classList.remove("hidden");
      }
    });
  });
</script>
