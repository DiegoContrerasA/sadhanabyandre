---
import { Image } from "astro:assets";
import aboutImg from "@/assets/images/me.jpeg";
import { useTranslations, getLang } from "@/i18n";

const about = useTranslations(getLang(Astro.currentLocale))("about");
---

<section id="sobre-mi" class="bg-primary-light py-24 md:py-32 px-6 md:px-12">
  <div class="max-w-7xl mx-auto grid grid-cols-1 lg:grid-cols-2 gap-20">

      <div data-animate class="relative max-w-md mx-auto lg:max-w-none">
          <div class="absolute  w-full h-full border border-primary top-[20px] left-[20px]"></div>
       <Image
          src={aboutImg}
          alt={about.imgAlt}
          width={560}
          fetchpriority="high"
          loading="eager"
          class="w-full object-cover aspect-4/5 relative z-1"
        />
      </div>
    <div>

      <p data-animate class=" text-[0.65rem] tracking-[0.35em] uppercase text-primary mb-5">
        {about.label}
      </p>

      <h2 data-animate data-delay="100" class=" text-4xl md:text-5xl lg:text-[3.5rem] font-light leading-tight  mb-8">
        {about.heading}<br />
        <em class="italic text-primary">{about.headingEm}</em>
      </h2>

      <div class="space-y-5 text-base leading-relaxed">
        <p data-animate data-delay="150">{about.p1}</p>
        <p data-animate data-delay="200">{about.p2}</p>
        <p data-animate data-delay="250">{about.p3}</p>
        <p data-animate data-delay="300">{about.p4}</p>

        <blockquote data-animate data-delay="350" class="mt-2 border-l-2 border-primary pl-5">
          <p class="text-primary italic text-lg md:text-xl font-light leading-snug">
            {about.quote}
          </p>
        </blockquote>
      </div>

      <div class="w-10 h-px bg-primary mt-10"></div>
    </div>
  </div>
</section>
