---
const whatsappUrl = "https://wa.me/1234567890?text=Hola%20Andre%2C%20me%20gustar%C3%ADa%20obtener%20m%C3%A1s%20informaci%C3%B3n%20sobre%20tus%20clases%20%F0%9F%99%8F";
---

<section class="relative overflow-hidden bg-primary px-8 py-24 md:px-16 md:py-32 lg:px-20">

  <!-- Decorative blobs -->
  <div class="absolute -top-24 -right-24 w-96 h-96 rounded-full opacity-20 pointer-events-none"
       style="background: radial-gradient(circle, #C969B7, transparent 70%)" aria-hidden="true"></div>
  <div class="absolute -bottom-20 -left-20 w-80 h-80 rounded-full opacity-15 pointer-events-none"
       style="background: radial-gradient(circle, #F8F3E8, transparent 70%)" aria-hidden="true"></div>

  <!-- Grain overlay -->
  <div class="absolute inset-0 opacity-[0.04] pointer-events-none"
       style="background-image: url(\"data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noise'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noise)'/%3E%3C/svg%3E\"); background-size: 180px 180px;"
       aria-hidden="true"></div>

  <!-- Content -->
  <div class="relative z-10 flex flex-col items-center text-center max-w-2xl mx-auto">

    <p class="text-[0.7rem] tracking-[0.22em] uppercase text-primary-light/50 mb-6 font-light">
      ¿Lista para comenzar?
    </p>

    <h2 class="font-light leading-[1.08] tracking-tight text-primary-light mb-6" style="font-size: clamp(2.2rem, 6vw, 4rem)">
      Hablemos y encontremos<br />
      <span class="italic" style="color: #DFC8CE;">la clase ideal para ti</span>
    </h2>

    <p class="text-primary-light/65 font-light leading-relaxed max-w-sm mb-10" style="font-size: clamp(0.85rem, 1.4vw, 1rem)">
      Escríbeme directamente por WhatsApp. Con gusto te cuento sobre los horarios,
      precios y qué modalidad se adapta mejor a tu vida.
    </p>

    <a
      href={whatsappUrl}
      target="_blank"
      rel="noopener noreferrer"
      class="inline-flex items-center gap-3 px-8 py-4 rounded-full bg-primary-light text-primary font-light text-sm tracking-wide transition-all duration-300 hover:scale-[1.03] hover:shadow-lg group"
      style="box-shadow: 0 0 0 0 rgba(248,243,232,0);"
    >
      <!-- WhatsApp icon -->
      <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="transition-transform duration-300 group-hover:scale-110" aria-hidden="true">
        <path d="M21 11.5a8.38 8.38 0 0 1-.9 3.8 8.5 8.5 0 0 1-7.6 4.7 8.38 8.38 0 0 1-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 0 1-.9-3.8 8.5 8.5 0 0 1 4.7-7.6 8.38 8.38 0 0 1 3.8-.9h.5a8.48 8.48 0 0 1 8 8v.5z"/>
      </svg>
      Escribir por WhatsApp
    </a>

    <!-- Subtle reassurance note -->
    <p class="mt-6 text-primary-light/30 text-[0.65rem] tracking-wide font-light">
      Sin compromisos · Respondo personalmente · Cupos limitados
    </p>

  </div>
</section>
