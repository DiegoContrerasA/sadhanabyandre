---
const imageModules = import.meta.glob<{ default: ImageMetadata }>(
  '../assets/gallery/*.jpeg',
  { eager: true }
);
const pool = Object.entries(imageModules)
  .sort(([a], [b]) => {
    const n = (p: string) => parseInt(p.split('/').pop()!.replace('.jpeg', ''));
    return n(a) - n(b);
  })
  .map(([, mod]) => mod.default);

const spanPattern = [
  { col: "col-span-2 md:row-span-2" },
  { col: "" },
  { col: "" },
  { col: "col-span-2" },
  { col: "" },
  { col: "" },
  { col: "col-span-2" },
  { col: "" },
  { col: "" },
  { col: "col-span-2" },
];

const photos = pool.map((src, i) => ({
  src:    src.src,
  width:  src.width,
  height: src.height,
  alt:    `Galería Sadhana by Andre — foto ${i + 1}`,
  span:   spanPattern[i % spanPattern.length],
}));
---

<section id="galeria" class="bg-primary-light px-6 md:px-12 py-24 md:py-32">
  <div class="max-w-7xl mx-auto">

    <!-- Top divider -->
    <div class="w-px h-16 bg-primary/25 mx-auto mb-16"></div>

    <!-- Header -->
    <div class="text-center mb-16">
      <p class=" text-[0.65rem] tracking-[0.35em] uppercase text-primary mb-4">
        Galería
      </p>
      <h2 class=" text-4xl md:text-5xl lg:text-6xl font-light text-dark">
        Encuentro de<br />
        <em class="italic text-primary">Bienestar 2026</em>
      </h2>
      <p class=" text-base text-dark/55 mt-6 max-w-lg mx-auto leading-relaxed">
        Imágenes del último evento realizado.
      </p>
    </div>

    <!-- Bento grid -->
    <div id="pswp-gallery" class="grid grid-cols-2 md:grid-cols-4 auto-rows-[200px] gap-3 md:gap-4">
      {photos.map((photo) => (
        <a
          href={photo.src}
          data-pswp-width={photo.width}
          data-pswp-height={photo.height}
          data-cropped="true"
          class={`relative overflow-hidden cursor-zoom-in group ${photo.span.col}`}
        >
          <img
            src={photo.src}
            alt={photo.alt}
            class="w-full h-full object-cover transition-all duration-700 group-hover:scale-105 group-hover:brightness-75 grayscale-[15%] group-hover:grayscale-0"
            loading="lazy"
          />

          <!-- Hover overlay -->
          <div class="absolute inset-0 opacity-0 group-hover:opacity-100 transition-opacity duration-300 flex items-center justify-center bg-primary/20">
            <div class="w-10 h-10 rounded-full bg-primary-light/80 flex items-center justify-center scale-75 group-hover:scale-100 transition-transform duration-300">
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-primary">
                <path d="M15 3h6v6M9 21H3v-6M21 3l-7 7M3 21l7-7"/>
              </svg>
            </div>
          </div>

          <!-- Grain texture -->
          <div class="absolute inset-0 pointer-events-none opacity-[0.04] mix-blend-overlay grain-cell" aria-hidden="true"></div>
        </a>
      ))}
    </div>

  </div>
</section>

<style>
  .grain-cell {
    background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 200 200' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noise'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.85' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noise)'/%3E%3C/svg%3E");
    background-size: 150px 150px;
  }
</style>

<script>
  import PhotoSwipeLightbox from 'photoswipe/lightbox';
  import 'photoswipe/style.css';

  const lightbox = new PhotoSwipeLightbox({
    gallery: '#pswp-gallery',
    children: 'a',
    pswpModule: () => import('photoswipe'),
  });

  lightbox.init();
</script>
