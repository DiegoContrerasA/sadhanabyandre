---
import { useTranslations, getLang } from "@/i18n";

const events = useTranslations(getLang(Astro.currentLocale))("events");
---

<section id="eventos" class="py-24 md:py-32 px-6 md:px-12">
  <div class="max-w-7xl mx-auto">

    <!-- Top divider -->
    <div class="w-px h-16 bg-primary/25 mx-auto mb-16"></div>

    <!-- Header -->
    <div class="text-center mb-20">
      <p class="text-[0.65rem] tracking-[0.35em] uppercase text-primary mb-4">
        {events.label}
      </p>
      <h2 class="text-4xl md:text-5xl lg:text-6xl font-light text-zinc-800">
        {events.heading}<br />
        <em class="italic text-primary">{events.headingEm}</em>
      </h2>
    </div>

    <!-- Events list -->
    <div class="space-y-8">
      {events.items.map((event) => (
        <div class="group relative border border-primary/15 p-8 md:p-12 overflow-hidden">

          <!-- Giant year watermark -->
          <span class="absolute -top-4 -right-4 text-[120px] md:text-[160px] font-light leading-none select-none pointer-events-none opacity-[0.06] text-primary">
            {event.year}
          </span>

          <div class="flex flex-col md:flex-row md:items-start gap-8 md:gap-12 relative z-10">

            <!-- Date column -->
            <div class="shrink-0">
              <p class="text-[10px] tracking-[0.3em] uppercase text-secondary mb-2">{event.type}</p>
              <p class="text-6xl md:text-7xl font-light leading-none text-primary">{event.day}</p>
              {event.date && (
                <p class="text-sm text-primary/60 mt-1">{event.date}</p>
              )}
            </div>

            <!-- Vertical divider -->
            <div class="hidden md:block w-px self-stretch bg-primary/15"></div>

            <!-- Content -->
            <div class="flex-1">
              <div class="flex items-center gap-2 mb-4">
                <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-secondary shrink-0">
                  <circle cx="12" cy="12" r="10"/><path d="m9 12 2 2 4-4"/>
                </svg>
                <span class="text-[10px] tracking-widest uppercase text-secondary">{events.statusBadge}</span>
              </div>
              <h3 class="text-2xl md:text-3xl lg:text-4xl font-light mb-4 text-primary">
                {event.title}
              </h3>
              <p class="text-base leading-relaxed text-zinc-500 max-w-xl">
                {event.description}
              </p>
            </div>

          </div>
        </div>
      ))}
    </div>

  </div>
</section>
