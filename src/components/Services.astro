---
import servicesImg from "@/assets/images/services.jpeg";
import { useTranslations, getLang } from "@/i18n";

const services = useTranslations(getLang(Astro.currentLocale))("services");
---

<section id="servicios" class="bg-primary-light px-6 md:px-12 py-24 md:py-32">
  <div class="max-w-7xl mx-auto">

    <!-- Top divider line -->
    <div class="w-px h-16 bg-primary/25 mx-auto mb-16"></div>

    <!-- Header -->
    <div class="text-center mb-20">
      <p data-animate class=" text-[0.65rem] tracking-[0.35em] uppercase text-primary mb-4">
        {services.label}
      </p>
      <h2 data-animate data-delay="100" class=" text-4xl md:text-5xl lg:text-6xl font-light">
        {services.heading} <em class="italic text-primary">{services.headingEm}</em>
      </h2>
    </div>

    <!-- Grid -->
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-20">

      <!-- Sticky image — hidden on mobile -->
      <div data-animate class="hidden lg:block" >
        <div class="sticky top-24">
          <img
            src={servicesImg.src}
            alt={services.imgAlt}
            loading="lazy"
            class="w-auto mx-auto object-cover max-h-[650px]"
          />
        </div>
      </div>

      <!-- Service list -->
      <div class="">
        {services.items.map((s, i) => (
          <div
            data-animate data-delay={i * 80}
            class="py-10 border-t border-dark/10 group"
          >
            <div class="flex items-start justify-between mb-4">
              <div>
                <span class=" text-xs tracking-[0.2em] text-dark/40">
                  {s.num}
                </span>
                <h3 class=" text-2xl md:text-3xl font-light text-dark mt-1 text-primary transition-colors duration-300">
                  {s.name}
                </h3>
              </div>
              <span class=" text-xs tracking-widest uppercase mt-2 shrink-0 text-primary">
                {s.duration}
              </span>
            </div>
            <div class="space-y-3 text-base leading-relaxed text-dark/60 max-w-md">
              {s.description.split("\n\n").map((p: string) => (
                <p>{p}</p>
              ))}
            </div>
          </div>
        ))}
        <div class="border-t border-dark/10"></div>
      </div>

    </div>
  </div>
</section>
