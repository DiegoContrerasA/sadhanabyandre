---
import { Image } from 'astro:assets';
import imgGrupal      from '../assets/images/WhatsApp Image 2026-04-17 at 11.52.40 AM.jpeg.jpg';
import imgPersonal    from '../assets/images/WhatsApp Image 2026-04-17 at 11.52.44 AM (1).jpeg.jpg';
import imgPrenatal    from '../assets/images/WhatsApp Image 2026-04-17 at 11.52.46 AM.jpeg.jpg';
import imgPostParto   from '../assets/images/WhatsApp Image 2026-04-17 at 11.52.48 AM.jpeg.jpg';
import imgFacial      from '../assets/images/WhatsApp Image 2026-04-17 at 11.52.43 AM (1).jpeg.jpg';

const servicios = [
  {
    id: 'grupal',
    nombre: 'Yoga Grupal',
    alt: 'Clase grupal de yoga con Andre, instructora certificada',
    img: imgGrupal,
    duracion: '60 min',
    nivel: 'Todos los niveles',
    horarios: 'Mar · Jue · Vie · Sáb',
    descripcion:
      'Vive la energía colectiva de la práctica compartida. Un espacio de apoyo donde cada persona avanza a su ritmo, con guía cercana y atención real.',
  },
  {
    id: 'personalizado',
    nombre: 'Yoga Personalizado',
    alt: 'Sesión de yoga personalizado adaptada a tus necesidades',
    img: imgPersonal,
    duracion: '75 min',
    nivel: 'Adaptado a ti',
    horarios: 'Previa cita',
    descripcion:
      'Una experiencia diseñada exclusivamente para tus metas y necesidades. Trabajamos juntas para construir una práctica que te transforme de adentro hacia afuera.',
  },
  {
    id: 'prenatal',
    nombre: 'Yoga Prenatal',
    alt: 'Yoga prenatal suave para embarazadas, clase con Andre',
    img: imgPrenatal,
    duracion: '60 min',
    nivel: 'Embarazadas',
    horarios: 'Consultar horario',
    descripcion:
      'Una práctica suave y amorosa para acompañar cada etapa del embarazo. Fortalece tu cuerpo, calma tu mente y conecta con el ser que crece en ti.',
  },
  {
    id: 'postparto',
    nombre: 'Yoga Post Parto',
    alt: 'Yoga post parto para recuperación y reconexión después del nacimiento',
    img: imgPostParto,
    duracion: '60 min',
    nivel: 'Post maternidad',
    horarios: 'Consultar horario',
    descripcion:
      'Un regreso suave al movimiento después del parto. Recupera tu fuerza, reconecta con tu cuerpo y encuentra calma en esta nueva etapa de tu vida.',
  },
  {
    id: 'facial',
    nombre: 'Yoga Facial',
    alt: 'Yoga facial con ejercicios y masajes para tonificar el rostro',
    img: imgFacial,
    duracion: '45 min',
    nivel: 'Todos los niveles',
    horarios: 'Consultar horario',
    descripcion:
      'Una práctica suave que trabaja los músculos del rostro a través de masajes, ejercicios y respiración. Tonifica, relaja y revitaliza tu expresión natural.',
  },
];
---

<section id="servicios" class="bg-[#0f0812] px-8 py-20 md:px-16 md:py-28 lg:px-20">

  <!-- Header -->
  <div class="max-w-2xl mb-14">
    <p class="text-[0.7rem] tracking-[0.22em] uppercase text-primary-light/40 mb-4 font-light">
      Lo que ofrezco
    </p>
    <h2 class="font-light leading-[1.05] tracking-tight text-primary-light mb-5" style="font-size: clamp(2.4rem, 6vw, 4.5rem)">
      Mis<br /><span class="text-secondary">Servicios</span>
    </h2>
    <p class="text-primary-light/55 font-light leading-relaxed max-w-md" style="font-size: clamp(0.85rem, 1.4vw, 1rem)">
      Cada servicio está pensado para acompañarte en un momento distinto de tu vida.
      Encuentra la práctica que resuena contigo hoy.
    </p>
  </div>

  <!-- Cards grid — bento even: 2 cols mobile, 3 md, 5 xl -->
  <div class="grid grid-cols-2 md:grid-cols-3 xl:grid-cols-5 gap-3 md:gap-4">
    {servicios.map((s) => (
      <article
        class="relative overflow-hidden rounded-2xl cursor-pointer select-none group"
        style="aspect-ratio: 3/4;"
        data-card
        data-id={s.id}
      >
        <!-- Image -->
        <Image
          src={s.img}
          alt={s.alt}
          class="absolute inset-0 w-full h-full object-cover object-center transition-transform duration-700 group-hover:scale-[1.04]"
          widths={[400, 700]}
          sizes="(max-width: 640px) 50vw, (max-width: 1024px) 33vw, 20vw"
        />

        <!-- Base gradient + name at bottom -->
        <div class="absolute inset-0 bg-gradient-to-t from-black/65 via-black/5 to-transparent">
          <div class="absolute bottom-0 left-0 right-0 p-4 transition-opacity duration-300 group-[.is-open]:opacity-0">
            <p class="text-[0.55rem] tracking-[0.16em] uppercase text-primary-light/50 mb-1 font-light">
              {s.duracion} · {s.nivel}
            </p>
            <h3 class="text-primary-light font-light leading-tight text-sm md:text-base">
              {s.nombre}
            </h3>
          </div>
        </div>

        <!-- Hover / mobile-always hint overlay -->
        <!--
          Mobile: opacity-20 always (subtle)
          Desktop: opacity-0 default → opacity-100 on hover
          Hidden when panel is open (.is-open)
        -->
        <div class="
          absolute inset-0 flex items-center justify-center
          transition-opacity duration-300
          opacity-20 md:opacity-0 md:group-hover:opacity-100
          group-[.is-open]:!opacity-0
          pointer-events-none
        ">
          <span class="
            px-3 py-1.5 rounded-full border border-primary-light/40
            bg-black/30 backdrop-blur-sm
            text-primary-light text-[0.6rem] tracking-[0.14em] uppercase font-light
          ">
            Click para más info
          </span>
        </div>

        <!-- Detail panel — slides up on click -->
        <div
          class="absolute inset-x-0 bottom-0 translate-y-full transition-transform duration-500 ease-[cubic-bezier(0.22,1,0.36,1)] detail-panel"
          style="background: linear-gradient(to top, rgba(156,70,132,0.97), rgba(156,70,132,0.93)); backdrop-filter: blur(8px);"
        >
          <div class="p-4 flex flex-col gap-2.5">
            <!-- Title + close -->
            <div class="flex items-start justify-between gap-2">
              <h3 class="text-primary-light font-light leading-tight text-sm md:text-base">
                {s.nombre}
              </h3>
              <span class="text-primary-light/40 text-xs mt-0.5 flex-shrink-0" aria-hidden="true">✕</span>
            </div>

            <!-- Meta pills -->
            <div class="flex flex-wrap gap-1">
              <span class="text-[0.55rem] tracking-wide uppercase px-2 py-1 rounded-full border border-primary-light/25 text-primary-light/65 font-light">
                {s.duracion}
              </span>
              <span class="text-[0.55rem] tracking-wide uppercase px-2 py-1 rounded-full border border-primary-light/25 text-primary-light/65 font-light">
                {s.nivel}
              </span>
              <span class="text-[0.55rem] tracking-wide uppercase px-2 py-1 rounded-full border border-primary-light/25 text-primary-light/65 font-light">
                {s.horarios}
              </span>
            </div>

            <!-- Description -->
            <p class="text-primary-light/75 font-light leading-relaxed text-xs md:text-sm">
              {s.descripcion}
            </p>

            <!-- CTA buttons -->
            <div class="flex gap-2 mt-1">
              <a
                href="#reserva"
                class="flex-1 text-center py-2 rounded-full bg-primary-light text-primary text-[0.65rem] font-light tracking-wide hover:opacity-90 transition-opacity"
                onclick="event.stopPropagation()"
              >
                Reservar
              </a>
              <a
                href="#info"
                class="flex-1 text-center py-2 rounded-full border border-primary-light/30 text-primary-light text-[0.65rem] font-light tracking-wide hover:bg-primary-light/10 transition-colors"
                onclick="event.stopPropagation()"
              >
                Más info
              </a>
            </div>
          </div>
        </div>
      </article>
    ))}
  </div>
</section>

<script>
  const cards = document.querySelectorAll('[data-card]');

  cards.forEach((card) => {
    card.addEventListener('click', () => {
      const panel = card.querySelector('.detail-panel') as HTMLElement;
      const isOpen = card.classList.contains('is-open');

      // Close all
      cards.forEach((c) => {
        c.classList.remove('is-open');
        const p = c.querySelector('.detail-panel') as HTMLElement;
        p.classList.add('translate-y-full');
        p.classList.remove('translate-y-0');
      });

      // Open if was closed
      if (!isOpen) {
        card.classList.add('is-open');
        panel.classList.remove('translate-y-full');
        panel.classList.add('translate-y-0');
      }
    });
  });
</script>
