---
const clases = [
  {
    dia: "Martes",
    hora: "7:00 am",
    modalidad: "Virtual",
    virtual: true,
    tag: "En línea",
    descripcion: "Inicia tu semana con energía desde donde estés.",
  },
  {
    dia: "Jueves",
    hora: "6:15 pm",
    modalidad: "Presencial",
    virtual: false,
    tag: "Presencial",
    descripcion: "Reconecta contigo al final del día.",
  },
  {
    dia: "Viernes",
    hora: "9:00 am",
    modalidad: "Presencial",
    virtual: false,
    tag: "Presencial",
    descripcion: "Cierra la semana laboral con movimiento consciente.",
  },
  {
    dia: "Sábado",
    hora: "7:00 am",
    modalidad: "Presencial",
    virtual: false,
    tag: "Presencial",
    descripcion: "Empieza el fin de semana con calma y presencia.",
  },
];
---

<section class="bg-primary-light px-8 py-20 md:px-16 md:py-28 lg:px-20">

  <!-- Header -->
  <div class="max-w-2xl mb-16">
    <p class="text-[0.7rem] tracking-[0.22em] uppercase text-primary/50 mb-4 font-light">
      Horarios
    </p>
    <h2 class="font-light leading-[1.05] tracking-tight text-primary mb-5" style="font-size: clamp(2.4rem, 6vw, 4.5rem)">
      Clases<br /><span class="text-secondary">Grupales</span>
    </h2>
    <p class="text-primary/60 font-light leading-relaxed max-w-md" style="font-size: clamp(0.85rem, 1.4vw, 1rem)">
      Un espacio para compartir, crecer y transformarse juntas. Nuestras clases grupales
      combinan técnica, respiración y comunidad para llevarte más lejos en tu práctica.
    </p>
  </div>

  <!-- Class list -->
  <div class="flex flex-col divide-y divide-primary/10">
    {clases.map((clase, i) => (
      <div
        class="group flex flex-col md:flex-row md:items-center gap-4 md:gap-0 py-7 transition-colors duration-200 hover:bg-primary/[0.03] -mx-4 px-4 rounded-xl"
      >
        <!-- Day + Time -->
        <div class="md:w-48 flex-shrink-0">
          <p class="text-[0.65rem] tracking-[0.14em] uppercase text-primary/40 font-light mb-1">
            Día / Hora
          </p>
          <p class="text-primary font-light leading-tight" style="font-size: clamp(1.1rem, 2vw, 1.35rem)">
            {clase.dia}
          </p>
          <p class="text-primary/70 font-light text-sm tracking-wide">
            {clase.hora}
          </p>
        </div>

        <!-- Divider vertical (desktop) -->
        <div class="hidden md:block w-px h-12 bg-primary/15 flex-shrink-0 mr-10 ml-4" aria-hidden="true"></div>

        <!-- Class name + description -->
        <div class="flex-1">
          <p class="text-[0.65rem] tracking-[0.14em] uppercase text-primary/40 font-light mb-1">
            Clase
          </p>
          <p class="text-primary font-light leading-snug" style="font-size: clamp(1.25rem, 2.5vw, 1.75rem)">
            Clase Grupal de Yoga
          </p>
          <p class="text-primary/55 font-light text-sm mt-0.5">{clase.descripcion}</p>
        </div>

        <!-- Badge + CTA -->
        <div class="flex items-center gap-3 md:ml-8 flex-shrink-0">
          <!-- Modality badge -->
          <span class={`inline-flex items-center gap-1.5 px-3 py-1.5 rounded-full text-[0.68rem] tracking-wide font-light border ${clase.virtual ? 'border-secondary/40 text-secondary bg-secondary/8' : 'border-primary/25 text-primary/70 bg-primary/5'}`}>
            <span class={`w-1.5 h-1.5 rounded-full flex-shrink-0 ${clase.virtual ? 'bg-secondary' : 'bg-primary/50'}`}></span>
            {clase.tag}
          </span>

          <!-- Reserve button -->
          <a
            href="#reserva"
            class="inline-flex items-center gap-2 px-5 py-2.5 rounded-full border border-primary/25 bg-transparent text-primary text-sm font-light tracking-wide transition-all duration-200 hover:bg-primary hover:text-primary-light hover:border-primary whitespace-nowrap"
          >
            Reservar
            <svg width="14" height="14" viewBox="0 0 18 18" fill="none" aria-hidden="true" class="transition-transform duration-200 group-hover:translate-x-0.5">
              <path d="M3.75 14.25L14.25 3.75M14.25 3.75H6.75M14.25 3.75V11.25" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </a>
        </div>
      </div>
    ))}
  </div>

  <!-- Bottom note -->
  <p class="mt-12 text-[0.72rem] tracking-[0.1em] uppercase text-primary/35 font-light">
    * Cupos limitados por clase — se recomienda reservar con anticipación.
  </p>

</section>
