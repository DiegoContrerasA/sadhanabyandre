---
import imgFuerza       from "@/assets/images/fuerza.jpeg";
import imgFlexibilidad from "@/assets/images/flexibilidad.jpeg";
import imgRestauracion from "@/assets/images/restauracion.jpeg";
import { useTranslations, getLang } from "@/i18n";

const positions = useTranslations(getLang(Astro.currentLocale))("positions");

const poses = [
  { src: imgFuerza,       ...positions.poses[0], tall: true  },
  { src: imgFlexibilidad, ...positions.poses[1], tall: false },
  { src: imgRestauracion, ...positions.poses[2], tall: false },
];
---

<section id="posturas" class="bg-primary-light px-6 md:px-12 py-24 md:py-32 overflow-hidden">
  <div class="max-w-7xl mx-auto">

    <!-- Top divider -->
    <div class="w-px h-16 bg-primary/25 mx-auto mb-16"></div>

    <!-- Header -->
    <div class="text-center mb-20">
      <p data-animate class="text-[0.65rem] tracking-[0.35em] uppercase text-primary mb-4">
        {positions.label}
      </p>
      <h2 data-animate data-delay="100" class="text-4xl md:text-5xl lg:text-6xl font-light">
        {positions.heading} <em class="italic text-primary">{positions.headingEm}</em>
      </h2>
    </div>

    <!-- Grid — 3 columnas -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-4 md:gap-5 items-start">
      {poses.map((p, i) => (
        <div data-animate data-delay={i * 100} class={`group relative overflow-hidden aspect-[3/4] ${i === 1 ? 'md:mt-10' : ''}`}>
          <img
            src={p.src.src}
            alt={p.alt}
            loading="lazy"
            class="w-full h-full object-cover object-center transition-transform duration-700 group-hover:scale-[1.04]"
          />
          <span class="absolute top-4 left-4 px-3 py-1 text-[10px] tracking-[0.22em] uppercase bg-primary text-white">
            {p.label}
          </span>
        </div>
      ))}
    </div>

    <!-- Bottom divider -->
    <div class="w-px h-16 bg-primary/25 mx-auto mt-16"></div>

  </div>
</section>
