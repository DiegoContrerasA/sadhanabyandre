---
import imgKobido from '../assets/images/call.jpeg';

const beneficios = [
  {
    titulo: "Efecto Lifting Natural",
    desc: "Reafirma los músculos faciales, redefiniendo el contorno facial sin cirugías.",
  },
  {
    titulo: "Rejuvenecimiento y Luminosidad",
    desc: "Atenúa arrugas, líneas de expresión y combate la flacidez, aportando frescura y luminosidad a la piel.",
  },
  {
    titulo: "Mejora la Circulación y Producción de Colágeno",
    desc: "Estimula la síntesis de colágeno y elastina, fortaleciendo la estructura dérmica y mejorando la textura de la piel.",
  },
  {
    titulo: "Drenaje Linfático y Detox",
    desc: "Ayuda a eliminar toxinas y reduce la retención de líquidos, disminuyendo la hinchazón facial y las ojeras.",
  },
  {
    titulo: "Relajación y Antiestrés",
    desc: "Alivia tensiones acumuladas en la mandíbula, cuello y cabeza, proporcionando un profundo bienestar físico y mental.",
  },
];
---

<section id="kobido" class="bg-primary-light px-6 md:px-12 py-24 md:py-32">
  <div class="max-w-7xl mx-auto">

    <!-- Top divider -->
    <div class="w-px h-16 bg-primary/25 mx-auto mb-16"></div>

    <!-- Header -->
    <div class="text-center mb-16">
      <p data-animate class=" text-[0.65rem] tracking-[0.35em] uppercase text-primary mb-4">
        Masaje Kobido
      </p>
      <h2 data-animate data-delay="100" class=" text-4xl md:text-5xl lg:text-6xl font-light text-dark">
        El arte del <em class="italic text-primary">lifting natural</em>
      </h2>
    </div>

    <!-- Grid — text left, image right -->
    <div class="grid grid-cols-1 md:grid-cols-12 gap-12 md:gap-16 items-center">

      <!-- Text — left -->
      <div class="md:col-span-6">

        <p data-animate data-delay="100" class="text-base md:text-lg leading-relaxed text-dark/60 mb-10">
          Conocido como el <em>"lifting facial japonés"</em>, es una técnica milenaria que rejuvenece el rostro de forma natural, reduciendo arrugas y líneas de expresión mediante estimulación profunda de músculos y tejidos. Sus beneficios incluyen el aumento de la producción de colágeno y elastina, la mejora de la circulación sanguínea, el drenaje linfático para reducir bolsas y ojeras, y una intensa relajación, ofreciendo resultados visibles desde la primera sesión.
        </p>

        <!-- Benefits -->
        <div class="space-y-5 mb-10">
          {beneficios.map((b, i) => (
            <div data-animate data-delay={200 + i * 80} class="flex items-start gap-4">
              <div class="w-1.5 h-1.5 rounded-full bg-primary shrink-0 mt-2"></div>
              <div>
                <p class="text-base font-medium text-dark">{b.titulo}</p>
                <p class="text-sm leading-relaxed text-dark/55 mt-0.5">{b.desc}</p>
              </div>
            </div>
          ))}
        </div>

        <!-- CTA -->
        <div data-animate data-delay="600" class="flex flex-col items-start gap-4">
          <a
            href="https://calendly.com/sadhanabyandre/30min"
            target="_blank"
            rel="noopener noreferrer"
            class="text-sm tracking-widest uppercase bg-primary text-primary-light px-8 py-4 hover:bg-secondary transition-colors duration-300"
          >
            Reservar Sesión
          </a>
          <span class="text-sm text-dark/45">Sesión individual · 120 min</span>
          <a
            href="https://wa.me/573122861377?text=¡Hola%20Andre!%20Tengo%20algunas%20dudas%20sobre%20el%20masaje%20Kobido%20y%20me%20gustaría%20saber%20más%20antes%20de%20reservar%20mi%20sesión."
            target="_blank"
            rel="noopener noreferrer"
            class="text-sm text-primary underline underline-offset-4 hover:text-secondary transition-colors duration-300"
          >
            ¿Tienes dudas? Hablamos por WhatsApp
          </a>
        </div>

      </div>

      <!-- Image — right -->
      <div data-animate data-delay="250" class="md:col-span-5 md:col-start-8">
        <div class="relative overflow-hidden">
          <img
            src={imgKobido.src}
            alt="Detalle de manos realizando masaje Kobido facial con aceites esenciales"
            loading="lazy"
            class="w-full object-cover aspect-[3/4]"
          />
        </div>
      </div>

    </div>
  </div>
</section>
