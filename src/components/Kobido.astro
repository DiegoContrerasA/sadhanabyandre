---
import { Image } from 'astro:assets';
import imgKobido from '../assets/images/WhatsApp Image 2026-04-17 at 11.52.47 AM (1).jpeg.jpg';

const whatsappUrl = "https://wa.me/1234567890?text=Hola%20Andre%2C%20me%20gustar%C3%ADa%20saber%20m%C3%A1s%20sobre%20el%20masaje%20Kobido%20%F0%9F%99%8F";

const beneficios = [
  "Efecto lifting natural sin agujas ni procedimientos invasivos",
  "Mejora la circulación y la luminosidad de la piel",
  "Tonifica los 16 músculos del rostro",
  "Reduce la tensión acumulada en mandíbula, sienes y frente",
  "Estimula la producción de colágeno",
  "Profundamente relajante — cuerpo y mente",
];
---

<section class="bg-primary-light overflow-hidden">
  <div class="flex flex-col lg:flex-row min-h-[85vh]">

    <!-- ── Left: image ── -->
    <div class="relative lg:w-[45%] min-h-[55vw] lg:min-h-0 order-2 lg:order-1">
      <Image
        src={imgKobido}
        alt="Masaje Kobido — Sadhana by Andre"
        class="w-full h-full object-cover object-center"
        widths={[600, 900, 1200]}
        sizes="(max-width: 1024px) 100vw, 45vw"
      />

      <!-- Overlay gradient right edge (desktop blend) -->
      <div
        class="hidden lg:block absolute inset-y-0 right-0 w-32 pointer-events-none"
        style="background: linear-gradient(to right, transparent, #F8F3E8)"
        aria-hidden="true"
      ></div>

      <!-- Floating badge -->
      <div class="absolute top-6 left-6 px-4 py-2 rounded-full backdrop-blur-md border border-primary-light/30"
           style="background: rgba(156,70,132,0.85)">
        <p class="text-primary-light text-[0.6rem] tracking-[0.18em] uppercase font-light">
          Nuevo servicio
        </p>
      </div>
    </div>

    <!-- ── Right: content ── -->
    <div class="flex flex-col justify-center px-8 py-16 md:px-14 lg:px-16 lg:w-[55%] order-1 lg:order-2">

      <!-- Eyebrow -->
      <p class="text-[0.7rem] tracking-[0.22em] uppercase text-primary/40 mb-5 font-light">
        Servicio destacado
      </p>

      <!-- Title -->
      <h2 class="font-light leading-[1.02] tracking-tight text-primary mb-3" style="font-size: clamp(2.8rem, 6vw, 5rem)">
        Masaje<br /><span class="text-secondary">Kobido</span>
      </h2>

      <!-- Japanese subtitle -->
      <p class="text-primary/30 font-light tracking-[0.3em] text-xs uppercase mb-8">
        古美道 · El camino de la belleza antigua
      </p>

      <!-- Description -->
      <div class="space-y-4 mb-10 max-w-lg">
        <p class="text-primary/70 font-light leading-relaxed" style="font-size: clamp(0.85rem, 1.3vw, 0.95rem)">
          El Kobido es una técnica ancestral japonesa de masaje facial que trabaja en
          profundidad los músculos, tejidos y meridianos del rostro. Su nombre significa
          <em>"el camino antiguo de la belleza"</em> — y eso es exactamente lo que es.
        </p>
        <p class="text-primary/70 font-light leading-relaxed" style="font-size: clamp(0.85rem, 1.3vw, 0.95rem)">
          A través de movimientos precisos y rítmicos, esta práctica devuelve tono,
          luminosidad y vitalidad al rostro de forma completamente natural, sin necesidad
          de procedimientos invasivos.
        </p>
      </div>

      <!-- Benefits -->
      <div class="mb-10">
        <p class="text-[0.62rem] tracking-[0.18em] uppercase text-primary/35 font-light mb-4">
          Beneficios
        </p>
        <ul class="space-y-2.5">
          {beneficios.map((b) => (
            <li class="flex items-start gap-3">
              <span class="mt-1.5 w-1 h-1 rounded-full bg-secondary flex-shrink-0" aria-hidden="true"></span>
              <span class="text-primary/65 font-light leading-snug" style="font-size: clamp(0.8rem, 1.2vw, 0.9rem)">
                {b}
              </span>
            </li>
          ))}
        </ul>
      </div>

      <!-- Divider -->
      <div class="w-12 h-px bg-primary/15 mb-8" aria-hidden="true"></div>

      <!-- CTA -->
      <div class="flex flex-col sm:flex-row items-start sm:items-center gap-4">
        <a
          href={whatsappUrl}
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-3 px-7 py-3.5 rounded-full bg-primary text-primary-light text-sm font-light tracking-wide transition-all duration-300 hover:bg-secondary hover:scale-[1.02] group"
        >
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" class="transition-transform duration-300 group-hover:scale-110">
            <path d="M21 11.5a8.38 8.38 0 0 1-.9 3.8 8.5 8.5 0 0 1-7.6 4.7 8.38 8.38 0 0 1-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 0 1-.9-3.8 8.5 8.5 0 0 1 4.7-7.6 8.38 8.38 0 0 1 3.8-.9h.5a8.48 8.48 0 0 1 8 8v.5z"/>
          </svg>
          Reservar Kobido
        </a>

        <p class="text-primary/35 text-[0.68rem] tracking-wide font-light leading-snug max-w-[200px]">
          Sesión individual · Duración aprox. 60 min · Cupos limitados
        </p>
      </div>

    </div>
  </div>
</section>
