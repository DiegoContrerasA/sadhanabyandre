---

<section class="bg-[#0f0812] py-20 md:py-28 overflow-hidden">

  <!-- Header -->
  <div class="px-8 md:px-16 lg:px-20 mb-14 flex flex-col md:flex-row md:items-end md:justify-between gap-6">
    <div>
      <p class="text-[0.7rem] tracking-[0.22em] uppercase text-primary-light/40 mb-4 font-light">
        Testimonios
      </p>
      <h2 class="font-light leading-[1.05] tracking-tight text-primary-light" style="font-size: clamp(2.4rem, 6vw, 4.5rem)">
        Lo que dicen<br /><span class="text-secondary">mis alumnas</span>
      </h2>
    </div>

    <!-- Arrow buttons -->
    <div class="flex items-center gap-3 md:mb-2">
      <button
        id="prev-btn"
        aria-label="Anterior"
        class="inline-flex items-center justify-center w-11 h-11 rounded-full border border-primary-light/25 text-primary-light/70 hover:border-primary-light/60 hover:text-primary-light transition-all duration-200"
      >
        <svg width="16" height="16" viewBox="0 0 18 18" fill="none" aria-hidden="true">
          <path d="M14.25 9H3.75M3.75 9L8.25 13.5M3.75 9L8.25 4.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </button>
      <button
        id="next-btn"
        aria-label="Siguiente"
        class="inline-flex items-center justify-center w-11 h-11 rounded-full border border-primary-light/25 text-primary-light/70 hover:border-primary-light/60 hover:text-primary-light transition-all duration-200"
      >
        <svg width="16" height="16" viewBox="0 0 18 18" fill="none" aria-hidden="true">
          <path d="M3.75 9H14.25M14.25 9L9.75 4.5M14.25 9L9.75 13.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </button>
    </div>
  </div>

  <!-- Carousel viewport -->
  <div class="relative">
    <!-- Left fade -->
    <div class="absolute left-0 top-0 bottom-0 w-16 md:w-28 z-10 pointer-events-none"
         style="background: linear-gradient(to right, #0f0812, transparent)" aria-hidden="true"></div>
    <!-- Right fade -->
    <div class="absolute right-0 top-0 bottom-0 w-16 md:w-28 z-10 pointer-events-none"
         style="background: linear-gradient(to left, #0f0812, transparent)" aria-hidden="true"></div>

    <div id="carousel-track" class="flex gap-4 transition-transform duration-500 ease-[cubic-bezier(0.22,1,0.36,1)] will-change-transform">
      <!-- Cards rendered 3× for seamless infinite loop -->
      {[...testimonios, ...testimonios, ...testimonios].map((t, i) => (
        <article
          class="carousel-card flex-shrink-0 w-[80vw] sm:w-[60vw] md:w-[38vw] lg:w-[28vw] xl:w-[22vw] rounded-2xl p-6 md:p-7 flex flex-col justify-between"
          style="background: rgba(248,243,232,0.05); border: 1px solid rgba(248,243,232,0.08);"
          aria-hidden={i < 10 || i >= 20 ? "true" : "false"}
        >
          <!-- Quote mark -->
          <div>
            <svg width="32" height="24" viewBox="0 0 32 24" fill="none" class="mb-4 opacity-60" aria-hidden="true">
              <path d="M0 24V14.4C0 6.4 4.8 1.6 14.4 0L16 2.4C11.2 3.6 8.4 6.4 8 10.4H14.4V24H0ZM17.6 24V14.4C17.6 6.4 22.4 1.6 32 0L33.6 2.4C28.8 3.6 26 6.4 25.6 10.4H32V24H17.6Z" fill="#C969B7"/>
            </svg>
            <p class="text-primary-light/80 font-light leading-relaxed" style="font-size: clamp(0.85rem, 1.3vw, 0.95rem)">
              {t.texto}
            </p>
          </div>

          <!-- Author -->
          <div class="mt-6 pt-5 border-t border-primary-light/10">
            <p class="text-primary-light font-light text-sm">{t.nombre}</p>
            <p class="text-primary-light/40 text-[0.72rem] tracking-wide font-light mt-0.5">{t.ciudad}</p>
          </div>
        </article>
      ))}
    </div>
  </div>
</section>

<script>
  const track  = document.getElementById('carousel-track') as HTMLElement;
  const prevBtn = document.getElementById('prev-btn') as HTMLButtonElement;
  const nextBtn = document.getElementById('next-btn') as HTMLButtonElement;

  const TOTAL = 10;
  let currentIndex = TOTAL; // start in the middle set

  function getCardWidth(): number {
    const card = track.querySelector('.carousel-card') as HTMLElement;
    const gap = 16; // gap-4 = 1rem = 16px
    return card.offsetWidth + gap;
  }

  function setPosition(animate: boolean) {
    if (!animate) track.style.transition = 'none';
    track.style.transform = `translateX(-${currentIndex * getCardWidth()}px)`;
    if (!animate) {
      // Force reflow then re-enable transition
      track.getBoundingClientRect();
      track.style.transition = '';
    }
  }

  function goNext() {
    currentIndex++;
    setPosition(true);
    if (currentIndex >= TOTAL * 2) {
      setTimeout(() => {
        currentIndex = TOTAL;
        setPosition(false);
      }, 520);
    }
  }

  function goPrev() {
    currentIndex--;
    setPosition(true);
    if (currentIndex < TOTAL) {
      setTimeout(() => {
        currentIndex = TOTAL * 2 - 1;
        setPosition(false);
      }, 520);
    }
  }

  // Init: jump to middle set with no animation
  setPosition(false);

  nextBtn.addEventListener('click', goNext);
  prevBtn.addEventListener('click', goPrev);

  // Recalculate on resize
  let resizeTimer: ReturnType<typeof setTimeout>;
  window.addEventListener('resize', () => {
    clearTimeout(resizeTimer);
    resizeTimer = setTimeout(() => setPosition(false), 150);
  });
</script>
