---
import { useTranslations, getLang } from "@/i18n";

const yf = useTranslations(getLang(Astro.currentLocale))("yogaFacial");

const wa = (msg: string) => `https://wa.me/573122861377?text=${encodeURIComponent(msg)}`;
---

<section id="yoga-facial" class="bg-white px-6 md:px-12 py-24 md:py-32">
  <div class="max-w-7xl mx-auto">

    <!-- Top divider -->
    <div class="w-px h-16 bg-primary/25 mx-auto mb-16"></div>

    <!-- Header -->
    <div class="text-center mb-16">
      <p data-animate class="text-[0.65rem] tracking-[0.35em] uppercase text-primary mb-4">
        {yf.label}
      </p>
      <h2 data-animate data-delay="100" class="text-4xl md:text-5xl lg:text-6xl font-light text-dark">
        {yf.heading} <em class="italic text-primary">{yf.headingEm}</em>
      </h2>
    </div>

    <!-- Grid — text left, video right -->
    <div class="grid grid-cols-1 md:grid-cols-12 gap-12 md:gap-16 items-center">

      <!-- Text — left -->
      <div class="md:col-span-6">

        <p data-animate data-delay="100" class="text-base md:text-lg leading-relaxed text-dark/60 mb-10">
          {yf.body}
        </p>

        <!-- Benefits -->
        <div class="space-y-5 mb-10">
          {yf.benefits.map((b, i) => (
            <div data-animate data-delay={200 + i * 80} class="flex items-start gap-4">
              <div class="w-1.5 h-1.5 rounded-full bg-primary shrink-0 mt-2"></div>
              <div>
                <p class="text-base font-medium text-dark">{b.title}</p>
                <p class="text-sm leading-relaxed text-dark/55 mt-0.5">{b.desc}</p>
              </div>
            </div>
          ))}
        </div>

        <!-- CTA -->
        <div data-animate data-delay="600" class="flex flex-col items-start gap-4">
          <a
            href={wa(yf.waMessage)}
            target="_blank"
            rel="noopener noreferrer"
            class="text-sm tracking-widest uppercase bg-primary text-primary-light px-8 py-4 hover:bg-secondary transition-colors duration-300"
          >
            {yf.cta}
          </a>
        </div>

      </div>

      <!-- Video — right -->
      <div data-animate data-delay="250" class="md:col-span-5 md:col-start-8">
        <div id="facial-wrapper" class="relative overflow-hidden aspect-[3/4] group">
          <video
            id="facial-video"
            src="/facial.mp4#t=1"
            playsinline
            preload="metadata"
            class="w-full h-full object-cover"
          ></video>

          <!-- Custom play/pause button -->
          <div
            id="facial-btn"
            aria-hidden="true"
            class="absolute inset-0 flex items-center justify-center transition-opacity duration-300 opacity-100 pointer-events-none"
          >
            <span id="facial-play" class="flex items-center justify-center w-16 h-16 rounded-full bg-primary/80 text-white backdrop-blur-sm">
              <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="currentColor">
                <polygon points="5,3 19,12 5,21"/>
              </svg>
            </span>
          </div>
        </div>
      </div>

    </div>
  </div>
</section>

<script>
  const video   = document.getElementById("facial-video") as HTMLVideoElement;
  const btn     = document.getElementById("facial-btn")!;

  const sync = () => {
    btn.style.opacity = (video.paused || video.ended) ? "1" : "0";
  };

  video.addEventListener("click", () => {
    video.paused ? video.play() : video.pause();
  });

  video.addEventListener("play", sync);
  video.addEventListener("pause", sync);
  video.addEventListener("ended", sync);
</script>
